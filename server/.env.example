# Server
PORT=4000
CORS_ORIGIN=http://localhost:5173

# Resend email provider
RESEND_API_KEY=your_resend_api_key
RESEND_FROM_EMAIL="CareSphere <no-reply@yourdomain.com>"

# OTP security + storage
OTP_PEPPER=your_random_secret_pepper
OTP_DB_PATH=./data/care-sphere.sqlite
OTP_EXPIRY_SECONDS=300
OTP_COOLDOWN_SECONDS=45
OTP_MAX_ATTEMPTS=5

# MongoDB + JWT auth
MONGODB_URI=mongodb://localhost:27017/care-sphere
JWT_SECRET=your_jwt_secret
JWT_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=12

# Basic abuse protection (in-memory, per IP)
OTP_IP_WINDOW_MS=600000
OTP_IP_MAX_SENDS=10

